APP_NAME="ISAMS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Manila
APP_URL=http://isams.test

DB_CONNECTION=pgsql
DB_HOST=YOUR_SUPABASE_POOLER_HOST
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres.YOURPROJECTREF
DB_PASSWORD=YOURPASSWORD
DB_SSLMODE=require

SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
QUEUE_CONNECTION=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@isams.edu.ph"
MAIL_FROM_NAME="${APP_NAME}"
